# =====================================================
# MINTORAIN 바이브코딩 - 환경변수 템플릿
# 사용법: cp .env.example .env.local 후 값 채우기
# 주의: .env, .env.local 은 절대 git에 커밋하지 말 것
# =====================================================

# --- Supabase (필수) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (선택, 사용 기능에 따라) ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
DID_API_KEY=
REPLICATE_API_TOKEN=
SUNO_API_KEY=

# --- 메시징 / 카카오톡 ---
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
KAKAO_CHANNEL_ID=
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# --- 이메일 자동화 ---
CONVERTKIT_API_SECRET=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# --- 광고 / 분석 ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- n8n 연동 ---
N8N_WEBHOOK_BASE_URL=https://mintorain.ai.kr
N8N_API_KEY=

# --- 알림 ---
SLACK_WEBHOOK_URL=

# --- 사이트 메타 ---
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=MINTORAIN 바이브코딩
